---
import BaseLayout from '../layouts/BaseLayout.astro';
import EssayCard from '../components/EssayCard.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import profilePhoto from '../assets/profile.jpg';

const allEssays = await getCollection('essays', ({ data }) => !data.draft);
const recent = allEssays
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 5);
---
<BaseLayout title="Home">
  <section class="intro">
    <div class="intro-header">
      <Image src={profilePhoto} alt="Vamsi Krishna" class="avatar" width={56} height={56} />
      <span class="name">Vamsi Krishna</span>
    </div>
    <p>
      I write about questions of existence, consciousness, and how they quietly shape the choices we make.
      My thinking is grounded in non-duality — Shankara, Vivekananda — alongside game theory, mathematics, and technology.
    </p>
    <p>
      <a href="/about">More about me →</a>
    </p>
  </section>

  {recent.length > 0 && (
    <section class="recent-essays">
      <h2>Recent Essays</h2>
      {recent.map(essay => (
        <EssayCard
          title={essay.data.title}
          description={essay.data.description}
          publishedAt={essay.data.publishedAt}
          slug={essay.slug}
          heroImage={essay.data.heroImage}
        />
      ))}
      <p class="all-link">
        <a href="/essays">All essays →</a>
      </p>
    </section>
  )}
</BaseLayout>

<style>
  .intro {
    margin-bottom: 3rem;
  }
  .intro-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .name {
    font-family: var(--font-ui);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .intro p {
    font-size: 1.1rem;
    color: var(--color-text);
    max-width: var(--measure);
  }
  .recent-essays h2 {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }
  .all-link {
    margin-top: 1.5rem;
    font-family: var(--font-ui);
    font-size: 0.9rem;
  }
</style>
